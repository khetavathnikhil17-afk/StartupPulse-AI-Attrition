# ══════════════════════════════════════════════════════════════════════════════
# StartupPulse AI — .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# ─── Virtual Environment ────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ─── IDE / Editor ───────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.project
.settings/
*.sublime-workspace
*.sublime-project

# ─── OS ─────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
*.tmp
*.bak

# ─── Environment / Secrets ──────────────────────────────────────────────────
.env
.env.local
.env.production
*.pem
*.key

# ─── Streamlit ──────────────────────────────────────────────────────────────
.streamlit/secrets.toml

# ─── Model Artifacts (large — regenerate or download) ───────────────────────
models/**/*.keras
models/**/*.h5
models/**/*.pkl
models/**/*.joblib
models/**/*.onnx
models/**/*.safetensors

# ─── Data (regenerate via preprocessing) ────────────────────────────────────
data/raw/*.csv
data/processed/*.csv

# ─── Generated Reports (regenerate via src modules) ─────────────────────────
reports/figures/*.html
reports/results/*.json
reports/results/*.md
reports/eda_summary_report.md

# ─── Logs ───────────────────────────────────────────────────────────────────
*.log
logs/

# ─── Jupyter ────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ─── Testing ────────────────────────────────────────────────────────────────
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# ─── TensorFlow ─────────────────────────────────────────────────────────────
*.tflite
saved_model/
train_output/
